import java.util.Scanner;

class Pelanggan {
    private String nomorPelanggan;
    private String nama;
    private double saldo;
    private String pin;
    private int salahInputPin = 0;
    private boolean terblokir = false;

    public Pelanggan(String nomorPelanggan, String nama, double saldo, String pin) {
        this.nomorPelanggan = nomorPelanggan;
        this.nama = nama;
        this.saldo = saldo;
        this.pin = pin;
    }

    // Getter (Enkapsulasi: informasi tidak bisa diubah langsung)
    public String getNomorPelanggan() { return nomorPelanggan; }
    public String getNama() { return nama; }
    public double getSaldo() { return saldo; }
    public boolean isTerblokir() { return terblokir; }

    public boolean cekPin(String inputPin) {
        if (terblokir) return false;
        if (this.pin.equals(inputPin)) {
            salahInputPin = 0;
            return true;
        } else {
            salahInputPin++;
            if (salahInputPin >= 3) {
                terblokir = true;
            }
            return false;
        }
    }

    public void topUp(double jumlah) {
        this.saldo += jumlah;
        System.out.println("Top up berhasil! Saldo sekarang: Rp" + String.format("%.2f", this.saldo));
    }

    public void beli(double totalBelanja) {
        double cashback = hitungCashback(totalBelanja);
        double totalPotongSaldo = totalBelanja - cashback;

        // Aturan saldo minimal Rp10.000
        if (this.saldo - totalPotongSaldo < 10000) {
            System.out.println("Transaksi GAGAL: Saldo pasca transaksi harus minimal Rp10.000");
        } else {
            this.saldo -= totalPotongSaldo;
            System.out.println("Transaksi BERHASIL!");
            System.out.println("Total Belanja: Rp" + totalBelanja);
            System.out.println("Cashback didapat: Rp" + cashback);
            System.out.println("Saldo dipotong: Rp" + totalPotongSaldo);
            System.out.println("Sisa Saldo: Rp" + String.format("%.2f", this.saldo));
        }
    }

    private double hitungCashback(double belanja) {
        String kode = nomorPelanggan.substring(0, 2);
        double persen = 0;

        switch (kode) {
            case "38": // Silver
                if (belanja > 1000000) persen = 0.05;
                break;
            case "56": // Gold
                persen = (belanja > 1000000) ? 0.07 : 0.02;
                break;
            case "74": // Platinum
                persen = (belanja > 1000000) ? 0.10 : 0.05;
                break;
        }
        return belanja * persen;
    }
}

public class SistemSwalayan {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        // Contoh data dummy (Nomor, Nama, Saldo Awal, PIN)
        Pelanggan p1 = new Pelanggan("5612345678", "Tama", 1500000, "1234");

        System.out.println("=== Selamat Datang di Swalayan Tiny ===");
        
        while (!p1.isTerblokir()) {
            System.out.print("\nMasukkan PIN: ");
            String inputPin = sc.next();

            if (p1.cekPin(inputPin)) {
                System.out.println("Halo, " + p1.getNama() + "!");
                System.out.println("1. Top Up\n2. Pembelian\n3. Keluar");
                System.out.print("Pilih menu: ");
                int menu = sc.nextInt();

                if (menu == 1) {
                    System.out.print("Masukkan jumlah Top Up: ");
                    p1.topUp(sc.nextDouble());
                } else if (menu == 2) {
                    System.out.print("Masukkan total belanja: ");
                    p1.beli(sc.nextDouble());
                } else {
                    break;
                }
            } else {
                if (p1.isTerblokir()) {
                    System.out.println("AKUN DIBLOKIR! Anda salah PIN 3 kali.");
                } else {
                    System.out.println("PIN Salah! Coba lagi.");
                }
            }
        }
        sc.close();
    }
}
